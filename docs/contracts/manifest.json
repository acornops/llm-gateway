{
  "repo": "llm-gateway",
  "version": 1,
  "runtimeDependencies": ["control-plane", "execution-engine"],
  "counterparts": {
    "execution-engine": {
      "streamPath": "POST /api/v1/llm/generations:stream",
      "toolCallPath": "POST /api/v1/mcp/tool-call",
      "internalTransportSecurity": "HTTP by default; HTTPS/mTLS when Helm internalTransport.tls.enabled=true; run-scoped JWTs remain required",
      "streamRequestFields": [
        "run_id",
        "workspace_id",
        "scope.type",
        "target_id",
        "target_type",
        "workflow_id",
        "workflow_run_id",
        "workflow_session_id",
        "workflow_step_id",
        "agent_id",
        "agent_version",
        "trigger_id",
        "session_id",
        "provider",
        "model",
        "messages",
        "temperature",
        "max_output_tokens",
        "reasoning",
        "tools",
        "native_tools"
      ],
      "streamResponseTypes": [
        "delta",
        "tool_call",
        "reasoning_summary_delta",
        "reasoning_summary_completed",
        "reasoning_summary_unavailable",
        "final",
        "error"
      ],
      "localDeterministicStreamEnv": "LLM_ENABLE_DETERMINISTIC_DEV_RESPONSES",
      "toolCallRequestFields": [
        "run_id",
        "workspace_id",
        "scope.type",
        "target_id",
        "target_type",
        "workflow_id",
        "workflow_run_id",
        "workflow_session_id",
        "workflow_step_id",
        "agent_id",
        "agent_version",
        "trigger_id",
        "tool",
        "arguments"
      ],
      "toolCallResponseFields": ["result", "is_error"]
    },
    "control-plane": {
      "adminPaths": [
        "GET /api/v1/internal/llm/provider-credentials",
        "PUT /api/v1/internal/llm/provider-credentials/{provider}",
        "DELETE /api/v1/internal/llm/provider-credentials/{provider}",
        "GET /api/v1/internal/mcp/servers",
        "GET /api/v1/internal/mcp/tools",
        "PATCH /api/v1/internal/mcp/tools/{tool_name}",
        "POST /api/v1/internal/mcp/servers",
        "PATCH /api/v1/internal/mcp/servers/{server_id}",
        "POST /api/v1/internal/mcp/servers/{server_id}/test",
        "DELETE /api/v1/internal/mcp/servers/{server_id}"
      ],
      "providerCredentialScope": "workspace-only: secret_name={provider}_api_key, tenant_scope={workspace_id}; target-scoped secrets are reserved for MCP/server credentials",
      "providerCredentialScopeFields": ["workspace_id"],
      "providerCredentialStatusFields": ["provider", "configured", "enabled"],
      "mcpRegistryScopeFields": ["workspace_id", "target_id", "target_type"],
      "serverFields": [
        "id",
        "workspace_id",
        "target_id",
        "target_type",
        "server_name",
        "server_url",
        "enabled",
        "auth_type",
        "auth_secret_name",
        "auth_header_name",
        "auth_header_prefix",
        "public_headers",
        "connection_status",
        "last_discovery_at",
        "last_discovery_error",
        "tools"
      ],
      "toolFields": [
        "name",
        "mcp_server_url",
        "timeout_ms",
        "description",
        "capability",
        "version",
        "source",
        "input_schema",
        "enabled"
      ],
      "jwksPath": "GET /api/v1/auth/jwks.json",
      "runJwtPermissionFields": [
        "allowed_providers",
        "allowed_models",
        "allowed_tools",
        "allowed_native_tools",
        "allowed_tool_operations?",
        "max_output_tokens"
      ],
      "runJwtWorkspaceScopeFields": [
        "scope.type",
        "workflow_id",
        "workflow_run_id",
        "workflow_session_id",
        "workflow_step_id?",
        "agent_id?",
        "agent_version?",
        "trigger_id?",
        "permissions.context_grants"
      ],
      "internalTransportSecurity": "HTTP by default; HTTPS/mTLS when Helm internalTransport.tls.enabled=true; admin/run-scoped bearer tokens remain required",
      "builtinBridge": {
        "serverName": "acornops-cluster-agent",
        "serverUrl": "http://control-plane:8081/internal/v1/mcp",
        "egressException": "Allowed internal HTTP only for configured builtin server registrations with source=builtin tools, auth type none, and no public headers",
        "authHeader": "Authorization: Bearer <run-scoped-jwt>",
        "scopeSource": "run-scoped-jwt-claims",
        "callPath": "POST /internal/v1/mcp/tools/call"
      }
    }
  }
}
